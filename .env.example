# Server-only Resend settings (configure these in Vercel; never prefix with VITE_)
RESEND_API_KEY=re_replace_with_your_api_key
RESEND_FROM_EMAIL=Wired Creations <inquiries@your-verified-domain.com>
LEAD_NOTIFICATION_EMAIL=info@wiredcreations.com
MONGODB_URI=mongodb+srv://replace_with_your_connection_string

# Cloudflare Turnstile: public site key for the browser and private secret for the API.
VITE_TURNSTILE_SITE_KEY=replace_with_your_turnstile_site_key
TURNSTILE_SECRET_KEY=replace_with_your_turnstile_secret_key

# Optional: only set this when the API is deployed on another origin.
# VITE_BACKEND_URI=https://api.example.com
